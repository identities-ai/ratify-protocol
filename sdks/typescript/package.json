{
  "name": "@identities-ai/ratify-protocol",
  "version": "1.0.0-alpha.6",
  "description": "Cryptographic delegation protocol for AI agents \u2014 TypeScript reference SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx/esm --test test/*.test.ts",
    "test:conformance": "node --import tsx/esm --test test/conformance.test.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ratify",
    "delegation",
    "agent",
    "ed25519",
    "ml-dsa",
    "post-quantum",
    "identity",
    "authorization",
    "ai-agents",
    "cryptography"
  ],
  "author": {
    "name": "Identities AI, Inc.",
    "email": "hello@identities.ai",
    "url": "https://identities.ai"
  },
  "homepage": "https://identities.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/identities-ai/ratify-protocol.git",
    "directory": "sdks/typescript"
  },
  "bugs": {
    "url": "https://github.com/identities-ai/ratify-protocol/issues",
    "email": "hello@identities.ai"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "@noble/post-quantum": "^0.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
